(Module (body (Expr (value (Constant (value '\nExample test suite for the h5i pytest integration.\n\nRun the full flow with:\n\n  # Option A — explicit adapter invocation\n  python ../../script/h5i-pytest-adapter.py -v > /tmp/h5i-results.json\n  h5i commit -m "feat: add math helpers" --test-results /tmp/h5i-results.json\n\n  # Option B — inline via --test-cmd\n  h5i commit -m "feat: add math helpers"     --test-cmd "python ../../script/h5i-pytest-adapter.py -q"\n\n  # Option C — env var (useful in CI / shell hooks)\n  python ../../script/h5i-pytest-adapter.py -q > /tmp/h5i-results.json\n  H5I_TEST_RESULTS=/tmp/h5i-results.json h5i commit -m "feat: add math helpers"\n\nAfter the commit, inspect the stored metrics with:\n  h5i log --limit 1\n')))) (FunctionDef (name 'add') (args (arguments (args (arg (arg 'a')) (arg (arg 'b'))))) (body (Return (value (BinOp (left (Name (id 'a'))) (op (Add)) (right (Name (id 'b')))))))) (FunctionDef (name 'subtract') (args (arguments (args (arg (arg 'a')) (arg (arg 'b'))))) (body (Return (value (BinOp (left (Name (id 'a'))) (op (Sub)) (right (Name (id 'b')))))))) (FunctionDef (name 'divide') (args (arguments (args (arg (arg 'a')) (arg (arg 'b'))))) (body (If (test (Compare (left (Name (id 'b'))) (ops (Eq)) (comparators (Constant (value 0))))) (body (Raise (exc (Call (func (Name (id 'ValueError'))) (args (Constant (value 'Division by zero')))))))) (Return (value (BinOp (left (Name (id 'a'))) (op (Div)) (right (Name (id 'b')))))))) (FunctionDef (name 'test_add_positive') (args (arguments)) (body (Assert (test (Compare (left (Call (func (Name (id 'add'))) (args (Constant (value 2)) (Constant (value 3))))) (ops (Eq)) (comparators (Constant (value 5)))))))) (FunctionDef (name 'test_add_negative') (args (arguments)) (body (Assert (test (Compare (left (Call (func (Name (id 'add'))) (args (UnaryOp (op (USub)) (operand (Constant (value 1)))) (UnaryOp (op (USub)) (operand (Constant (value 1))))))) (ops (Eq)) (comparators (UnaryOp (op (USub)) (op