{
  "enabledPlugins": {},
  "env": {
    "H5I_AGENT": "claude"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "h5i hook run",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Read"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "h5i hook session-start",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "h5i msg hook --block",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "h5i hook stop",
            "type": "command"
          }
        ]
      }
    ]
  }
}