{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "h5i hook run"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "h5i msg hook"
          }
        ]
      }
    ]
  },
  "env": {
    "H5I_AGENT": "claude"
  },
  "enabledPlugins": {}
}
