{
  "enabledPlugins": {},
  "env": {
    "H5I_AGENT": "claude"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "h5i claude sync",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Read"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "h5i hook wrap-bash",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "h5i hook session-start",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "h5i msg hook --block",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "h5i claude finish",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "h5i hook prompt",
            "type": "command"
          }
        ]
      }
    ]
  }
}