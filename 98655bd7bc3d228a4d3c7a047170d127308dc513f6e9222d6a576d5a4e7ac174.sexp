(Module (body (Expr (value (Constant (value '\nh5i pytest adapter — runs pytest and writes h5i-compatible test results JSON.\n\nUsage (standalone):\n    python script/h5i-pytest-adapter.py [pytest-args...]\n\nUsage (pipe into h5i commit):\n    python script/h5i-pytest-adapter.py -q > /tmp/h5i-results.json\n    h5i commit -m "..." --test-results /tmp/h5i-results.json\n\nUsage (one-liner with --test-cmd):\n    h5i commit -m "..." --test-cmd "python script/h5i-pytest-adapter.py -q"\n\nEnvironment variables:\n    H5I_TEST_OUTPUT   Path where the JSON is written (default: stdout).\n    PYTEST_ARGS       Extra arguments forwarded to pytest.\n\nThe script exits with pytest\'s own exit code, so CI pipelines can gate on it.\n')))) (Import (names (alias (name 'json')))) (Import (names (alias (name 'os')))) (Import (names (alias (name 'subprocess')))) (Import (names (alias (name 'sys')))) (Import (names (alias (name 'time')))) (FunctionDef (name 'run_pytest') (args (arguments (args (arg (arg 'extra_args'))))) (body (Expr (value (Constant (value 'Run pytest with JSON report plugin and return (returncode, report_path).')))) (Import (names (alias (name 'tempfile')))) (Assign (targets (Tuple (elts (Name (id 'report_fd')) (Name (id 'report_path'))))) (value (Call (func (Attribute (value (Name (id 'tempfile'))) (attr 'mkstemp'))) (keywords (keyword (arg 'suffix') (value (Constant (value '.json')))) (keyword (arg 'prefix') (value (Constant (value 'h5i-pytest-')))))))) (Expr (value (Call (func (Attribute (value (Name (id 'os'))) (attr 'close'))) (args (Name (id 'report_fd')))))) (Assign (targets (Name (id 'cmd'))) (value (BinOp (left (List (elts (Attribute (value (Name (id 'sys'))) (attr 'executable')) (Constant (value '-m')) (Constant (value 'pytest')) (JoinedStr (values (Constant (value '--json-report')))) (JoinedStr (values (Constant (value '--json-report-file=')) (FormattedValue (value (Name (id 'report_path'))) (conversion -1)))) (Constant (value '--tb=short')) (Constant (value '